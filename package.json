{
	"name": "plotrix",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"generate-pwa-assets": "pwa-assets-generator",
		"prepare": "svelte-kit sync || echo ''",
