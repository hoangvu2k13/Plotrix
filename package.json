		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25",
		"@vite-pwa/assets-generator": "^1.0.2",
		"esbuild": "^0.27.4",
		"eslint": "10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"typescript": "6.0.2",
		"typescript-eslint": "8.57.2",
