		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"color-thief-browser": "^2.0.2",
		"katex": "^0.16.43",
		"mathjs": "^15.1.1",
		"nanoid": "^5.1.7",
		"svelte-motion": "^0.12.2",
		"svelte-portal": "^2.2.1",
		"vite-plugin-compression2": "^2.5.3"
	}
